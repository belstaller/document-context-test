{
  "name": "document-context-test",
  "version": "0.1.0",
  "private": true,
  "description": "Document management platform — Next.js, React, PostgreSQL, Python microservices, Docker",
  "workspaces": [
    "web",
    "services/api-gateway"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace=web",
    "dev:api": "npm run dev --workspace=services/api-gateway",
    "build": "npm run build --workspaces",
    "lint": "eslint \"src/**/*.{ts,tsx}\" \"web/**/*.{ts,tsx}\" \"services/api-gateway/**/*.{ts,tsx}\"",
    "format": "prettier --write \"src/**/*.{ts,tsx,json}\" \"web/**/*.{ts,tsx,json}\" \"services/api-gateway/**/*.{ts,tsx,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,json}\"",
    "type-check": "tsc --noEmit",
    "migrate": "npm run migrate --workspace=services/api-gateway",
    "test": "jest --passWithNoTests"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.12.7",
    "@typescript-eslint/eslint-plugin": "^7.8.0",
    "@typescript-eslint/parser": "^7.8.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.3",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "jest": "^29.7.0",
    "prettier": "^3.2.5",
    "ts-jest": "^29.1.2",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
